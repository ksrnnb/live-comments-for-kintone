{
  "manifest_version": 3,
  "name": "Live Comments for kintone",
  "version": "0.0.1",
  "description": "kintone の新着コメント通知バナーを自動でクリックして展開します。",
  "content_scripts": [
    {
      "matches": [
        "https://*.cybozu.com/k/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}