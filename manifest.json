{
  "manifest_version": 3,
  "name": "Live Comments for kintone",
  "version": "0.0.2",
  "description": "kintone の新着コメント通知バナーを自動でクリックして展開します。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Live Comments for kintone"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.cybozu.com/k/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
